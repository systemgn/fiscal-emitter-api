# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# ── MySQL ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=fiscal_emitter

# ── Redis (BullMQ) ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Queue ────────────────────────────────────────────────────────
# Concorrência do worker por fila
QUEUE_EMIT_CONCURRENCY=5
QUEUE_CANCEL_CONCURRENCY=3
QUEUE_EXPORT_CONCURRENCY=2
# Tentativas e backoff (ms)
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000

# ── NFS-e Nacional ───────────────────────────────────────────────
NFSE_NACIONAL_SANDBOX_URL=https://sandbox.nfse.gov.br
NFSE_NACIONAL_PRODUCTION_URL=https://nfse.gov.br

# ── Segurança ────────────────────────────────────────────────────
BCRYPT_ROUNDS=10
