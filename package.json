{
  "name": "fiscal-emitter-api",
  "version": "3.0.1",
  "description": "NFS-e Nacional Emitter API — Multi-tenant SaaS",
  "author": "Fiscal Emitter",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:worker": "nest start --watch --entryFile worker/worker-entry",
    "start:worker:prod": "node dist/worker/worker-entry",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "db:migrate:v2": "mysql -h $DB_HOST -P $DB_PORT -u $DB_USER -p$DB_PASSWORD $DB_NAME < database/migrations/v2.sql"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/swagger": "^7.3.0",
    "@bull-board/api": "^5.19.0",
    "@bull-board/express": "^5.19.0",
    "@bull-board/nestjs": "^5.19.0",
    "typeorm": "^0.3.20",
    "mysql2": "^3.9.2",
    "bullmq": "^5.4.2",
    "ioredis": "^5.3.2",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "bcrypt": "^5.1.1",
    "uuid": "^9.0.1",
    "axios": "^1.6.8",
    "node-forge": "^1.3.1",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.1",
    "prom-client": "^15.1.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/node-forge": "^1.3.11",
    "@types/uuid": "^9.0.8",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@common/(.*)": "<rootDir>/common/$1",
      "@config/(.*)": "<rootDir>/config/$1",
      "@modules/(.*)": "<rootDir>/modules/$1",
      "@infra/(.*)": "<rootDir>/infrastructure/$1",
      "@worker/(.*)": "<rootDir>/worker/$1"
    }
  }
}
